# SAP ADT Connection Configuration
# 
# This file contains environment variables for connecting to your SAP S/4HANA system.
# 
# IMPORTANT: 
# - Copy this file to .env and fill in your actual values
# - NEVER commit the .env file to version control
# - Keep credentials secure - use vault services in production
# - Ensure the user has S_TRANSPRT and S_DEVELOP authorizations

# SAP System Host URL
# Format: https://hostname:port or http://hostname:port
# Port: Typically 44300 (HTTPS) or 8000 (HTTP) for S/4HANA
# Example: https://sap-prod.company.com:44300
SAP_HOST=https://your-sap-system.example.com:44300

# SAP Client Number
# Default: 100 (change if your system uses different client)
# Range: 000-999
SAP_CLIENT=100

# SAP ABAP Username
# Must have authorizations:
#   - S_TRANSPRT: Transport Management
#   - S_DEVELOP: ABAP Development Environment
# Example: DEVELOPER001
SAP_USER=your_abap_user

# SAP ABAP User Password
# For production, use a vault service instead of storing plaintext passwords
# Example: MySecureP@ssw0rd
SAP_PASSWORD=your_secure_password

# Optional: Logging Level (future enhancement)
# Values: DEBUG, INFO, WARN, ERROR
# LOG_LEVEL=INFO

# Optional: Request Timeout (milliseconds)
# Default: 15000 (15 seconds)
# REQUEST_TIMEOUT=15000

# Optional: Enable SSL Certificate Validation
# Values: true (production), false (development with self-signed certs)
# Default: false (current)
# SSL_VERIFY=false

# Optional: Path to CA Certificate Bundle (if using custom SSL certs)
# Example: /etc/ssl/certs/ca-bundle.pem
# CA_BUNDLE_PATH=

# Optional: Proxy Configuration (if behind corporate proxy)
# HTTP_PROXY=http://proxy.company.com:8080
# HTTPS_PROXY=https://proxy.company.com:8080
# NO_PROXY=localhost,127.0.0.1

# Optional: MCP Server Port (if running standalone)
# Default: 3000
# SERVER_PORT=3000

# Optional: Debug Mode (logs to debug.log)
# Values: true, false
# DEBUG_MODE=true
